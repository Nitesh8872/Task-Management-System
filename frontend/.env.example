# Backend URL — server ROOT only (no trailing slash, no /api/users).
# Vite bakes this into the build at compile time. Changing it in Netlify
# requires a new deploy (Build & deploy → Trigger deploy).
#
# Local development:
VITE_API_URL=http://localhost:5000
#
# Production (Railway):
# VITE_API_URL=https://task-management-system-production-0d38.up.railway.app
#
# Also valid (API prefix form):
# VITE_API_URL=https://task-management-system-production-0d38.up.railway.app/api
